[Unit]
Description=PowerGateway Stromzaehler-Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=powergateway
Group=powergateway
ExecStart=/opt/powergateway/venv/bin/python /opt/powergateway/src/service.py
Restart=on-failure
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/powergateway
SupplementaryGroups=dialout

[Install]
WantedBy=multi-user.target
